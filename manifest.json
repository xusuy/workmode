{
  "manifest_version": 3,
  "name": "WorkMode",
  "version": "1.1.0",
  "description": "职场文档视力保护器/沉浸式阅读助手，按 Alt+W 一键切换沉浸式体验",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config-loader.js", "content.js"],
      "css": ["wps-style.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["platform-configs/*.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
